# --- APP CONFIG ---
APP_NAME="Second Brain Research Lab"
APP_HOST=127.0.0.1
APP_PORT=8765

# --- DATABASE (Supabase or Local) ---
# Local: postgresql://postgres:postgres@127.0.0.1:5433/second_brain
# Supabase: postgresql://postgres:[PASSWORD]@[HOST].supabase.co:5432/postgres
POSTGRES_DSN=postgresql://postgres:postgres@127.0.0.1:5433/second_brain
POSTGRES_SCHEMA=research

# --- OLLAMA (Local LLM) ---
OLLAMA_BASE_URL=http://127.0.0.1:11434

# --- CLOUD LLM (Gemini API) ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- EMBEDDINGS ---
DEFAULT_EMBEDDING_MODEL=all-MiniLM-L6-v2
DEFAULT_EMBEDDING_DIMENSIONS=384
